DATABASE_URL=postgresql+psycopg://drone_user:drone_password@localhost:5432/drone_strike
APP_NAME=Drone Strike API
APP_ENV=local
# Set APP_ENV=production to disable public /docs, /redoc, and /openapi.json.
API_V1_PREFIX=/api/v1
JWT_SECRET_KEY=dev-secret-change-me-dev-only-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
LEGAL_TERMS_VERSION=1.0
LEGAL_PERSONAL_DATA_VERSION=1.0
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FPV Last Run
SMTP_USE_TLS=true
